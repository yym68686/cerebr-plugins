{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cerebr.dev/schemas/plugin.schema.json",
  "title": "Cerebr Plugin Package",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "version",
    "kind",
    "scope",
    "displayName",
    "description"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "kind": {
      "type": "string",
      "enum": ["builtin", "declarative", "script"]
    },
    "scope": {
      "type": "string",
      "enum": ["page", "shell", "prompt", "background"]
    },
    "displayName": {
      "type": "string",
      "minLength": 1
    },
    "nameKey": {
      "type": "string"
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "descriptionKey": {
      "type": "string"
    },
    "defaultEnabled": {
      "type": "boolean"
    },
    "publisher": {
      "type": "string"
    },
    "homepage": {
      "type": "string"
    },
    "permissions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "requiresExtension": {
      "type": "boolean"
    },
    "compatibility": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "versionRange": {
          "type": "string"
        }
      }
    },
    "declarative": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["prompt_fragment", "request_policy", "page_extractor"]
        },
        "placement": {
          "type": "string",
          "enum": ["system.prepend", "system.append"]
        },
        "content": {
          "type": "string"
        },
        "contentKey": {
          "type": "string"
        },
        "priority": {
          "type": "number"
        },
        "applyTo": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "modes": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "modelIncludes": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "urlIncludes": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        },
        "promptFragments": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "object",
              "additionalProperties": false,
              "anyOf": [
                {
                  "required": ["content"]
                },
                {
                  "required": ["contentKey"]
                }
              ],
              "properties": {
                "content": {
                  "type": "string"
                },
                "contentKey": {
                  "type": "string"
                },
                "placement": {
                  "type": "string",
                  "enum": ["system.prepend", "system.append"]
                },
                "priority": {
                  "type": "number"
                }
              }
            },
            {
              "type": "array",
              "items": {
                "oneOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "object",
                    "additionalProperties": false,
                    "anyOf": [
                      {
                        "required": ["content"]
                      },
                      {
                        "required": ["contentKey"]
                      }
                    ],
                    "properties": {
                      "content": {
                        "type": "string"
                      },
                      "contentKey": {
                        "type": "string"
                      },
                      "placement": {
                        "type": "string",
                        "enum": ["system.prepend", "system.append"]
                      },
                      "priority": {
                        "type": "number"
                      }
                    }
                  }
                ]
              }
            }
          ]
        },
        "requestPatch": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "url": {
              "type": "string"
            },
            "headers": {
              "type": "object",
              "additionalProperties": {
                "type": "string"
              }
            },
            "body": {
              "type": "object"
            }
          }
        },
        "retry": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "onErrorCodes": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "maxAttempts": {
              "type": "integer",
              "minimum": 1
            },
            "reason": {
              "type": "string"
            }
          }
        },
        "cancel": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "draftMatches": {
              "type": "string"
            },
            "draftIncludes": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "reason": {
              "type": "string"
            }
          }
        },
        "matches": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "includeSelectors": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "excludeSelectors": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "selectors": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "include": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "exclude": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        },
        "strategy": {
          "type": "string",
          "enum": ["replace", "prepend", "append"]
        },
        "maxTextLength": {
          "type": "integer",
          "minimum": 1
        },
        "collapseWhitespace": {
          "type": "boolean"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "type": {
                "const": "prompt_fragment"
              }
            }
          },
          "then": {
            "required": ["placement"],
            "anyOf": [
              {
                "required": ["content"]
              },
              {
                "required": ["contentKey"]
              }
            ]
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "request_policy"
              }
            }
          },
          "then": {
            "anyOf": [
              {
                "required": ["promptFragments"]
              },
              {
                "required": ["requestPatch"]
              },
              {
                "required": ["retry"]
              },
              {
                "required": ["cancel"]
              }
            ]
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "page_extractor"
              }
            }
          },
          "then": {
            "properties": {
              "strategy": {
                "enum": ["replace", "prepend", "append"]
              }
            }
          }
        }
      ]
    },
    "script": {
      "type": "object",
      "additionalProperties": false,
      "required": ["entry"],
      "properties": {
        "entry": {
          "type": "string",
          "minLength": 1
        },
        "exportName": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "kind": {
            "const": "declarative"
          }
        }
      },
      "then": {
        "required": ["declarative"]
      }
    },
    {
      "if": {
        "properties": {
          "kind": {
            "const": "script"
          }
        }
      },
      "then": {
        "required": ["script"],
        "properties": {
          "scope": {
            "enum": ["page", "shell", "background"]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "scope": {
            "const": "background"
          }
        }
      },
      "then": {
        "required": ["requiresExtension"],
        "properties": {
          "requiresExtension": {
            "const": true
          }
        }
      }
    }
  ]
}
